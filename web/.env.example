# Server-only (do NOT prefix with NEXT_PUBLIC)
SCRAPE_ANALYZE_URL=https://<project-ref>.supabase.co/functions/v1/scrape_analyze
# Optional. Defaults to the same host path with /discover_targets instead of /scrape_analyze
# DISCOVER_TARGETS_URL=https://<project-ref>.supabase.co/functions/v1/discover_targets
# Optional. Defaults to .../analyze_target
# ANALYZE_TARGET_URL=https://<project-ref>.supabase.co/functions/v1/analyze_target
# Optional. Defaults to .../list_project_targets
# LIST_PROJECT_TARGETS_URL=https://<project-ref>.supabase.co/functions/v1/list_project_targets
SCRAPE_ANALYZE_SECRET=change-me
