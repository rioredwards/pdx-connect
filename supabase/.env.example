# Copy to supabase/.env.local for local development
# Used by Supabase Edge Functions when running locally (supabase functions serve)

SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=your_local_service_role_key

FIRECRAWL_API_KEY=fc-your-firecrawl-key
OPENAI_API_KEY=sk-your-openai-key

# Shared secret for authorizing calls to the Edge Function (Bearer token)
# Must match `SCRAPE_ANALYZE_SECRET` in your Next.js (Vercel) environment.
FUNCTION_AUTH_SECRET=change-me

# For discover_targets: Google key with Places API (New) + billing. Dashboard name may be google_maps_api_key
# GOOGLE_MAPS_API_KEY=
